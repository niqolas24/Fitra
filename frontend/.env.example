# Auth.js / NextAuth — required in production
AUTH_SECRET=generate_with_openssl_rand_base64_32
# Public URL of the app (use your AWS domain in production)
AUTH_URL=http://localhost:3000

# Google OAuth (optional) — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email login now uses the database via /api/auth/login and /api/auth/signup
# Users sign up through the UI and credentials are stored in your PostgreSQL database

# Set to "false" to hide the Google button when OAuth is not configured
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# Backend API (browser → FastAPI; set to your AWS API URL in production)
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- AWS (typical setup) ---
# 1) Run API on ECS/Fargate or Elastic Beanstalk; front end on Amplify Hosting, App Runner, or ECS behind ALB.
# 2) Set AUTH_URL to the public HTTPS URL of this Next app (required for OAuth callbacks).
# 3) In Google Cloud Console, add redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
# 4) Store AUTH_SECRET, OAuth secrets, and AUTH_PASSWORD_HASH in AWS Secrets Manager or SSM, injected as env at runtime.
# 5) Docker: from frontend/, docker build --build-arg NEXT_PUBLIC_API_URL=https://api.example.com -t fitra-web .
